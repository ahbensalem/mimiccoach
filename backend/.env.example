# Qdrant Cloud (https://cloud.qdrant.io)
QDRANT_URL=https://YOUR-CLUSTER.qdrant.io:6333
QDRANT_API_KEY=

# Storage for pose JSON + (optionally) pro video clips.
# In production: Modal Volume or Cloudflare R2 / S3-compatible.
# For local dev: leave blank to use the local filesystem.
STORAGE_BACKEND=local       # local | r2 | s3
STORAGE_BUCKET=
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Pose / embedding pipeline
MEDIAPIPE_MODEL_PATH=                 # leave blank to use bundled landmarker
MOTIONBERT_CKPT=walterzhu/MotionBERT  # HF repo id
EMBED_DEVICE=auto                     # auto | cpu | cuda

# CORS / frontend origin
FRONTEND_ORIGIN=http://localhost:3000
